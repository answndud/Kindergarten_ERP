# ===========================================
# Docker Compose local infrastructure example
# Copy to docker/.env before running compose.
# This file is for local MySQL/Redis only.
# App process secrets like JWT_SECRET or OAuth client secrets
# must be supplied to the Spring Boot process separately.
# ===========================================

# MySQL
MYSQL_ROOT_PASSWORD=root1234
MYSQL_DATABASE=erp_db
MYSQL_USER=erp_user
MYSQL_PASSWORD=erp1234

# Local-only bind defaults
DOCKER_BIND_HOST=127.0.0.1
MYSQL_PUBLISHED_PORT=3306
REDIS_PUBLISHED_PORT=6379
PROMETHEUS_PUBLISHED_PORT=9090
GRAFANA_PUBLISHED_PORT=3000

# Grafana local demo credentials
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin1234!
